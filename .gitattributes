# Normalize line endings: LF in the repo and on checkout, regardless of the
# contributor's OS or core.autocrlf setting. Without this, Windows checkouts get
# CRLF working trees that fail `prettier --check` (endOfLine: lf) locally.
* text=auto eol=lf

# Binary assets — never normalize or diff as text.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
